{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"],
      "@/app": ["./src/app"],
      "@/app/*": ["./src/app/*"],
      "@/features": ["./src/features"],
      "@/features/*": ["./src/features/*"],
      "@/components": ["./src/components"],
      "@/components/*": ["./src/components/*"],
      "@/hooks": ["./src/hooks"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/context": ["./src/context"],
      "@/context/*": ["./src/context/*"],
      "@/services": ["./src/services"],
      "@/services/*": ["./src/services/*"],
      "@/api": ["./src/services/api"],
      "@/api/*": ["./src/services/api/*"],
      "@/utils": ["./src/utils"],
      "@/utils/*": ["./src/utils/*"],
      "@/constants": ["./src/constants"],
      "@/constants/*": ["./src/constants/*"],
      "@/locales": ["./src/locales"],
      "@/locales/*": ["./src/locales/*"],
      "@/styles": ["./src/styles"],
      "@/styles/*": ["./src/styles/*"],
      "@/assets": ["./src/assets"],
      "@/assets/*": ["./src/assets/*"]
    }
  },
  "include": ["src"]
}